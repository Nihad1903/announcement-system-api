# ============================================
# DJANGO CORE SETTINGS
# ============================================

# Django Secret Key - Generate a new one for production!
# Generate at: https://djecrety.ir/ or use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug Mode - Set to False in production!
DEBUG=True

# Allowed Hosts - Comma separated list of domains
# Example: localhost,127.0.0.1,example.com,www.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# DATABASE SETTINGS
# ============================================

# Database Engine Options:
# - sqlite3 (default, for development)
# - postgresql
# - mysql
# - oracle
DB_ENGINE=sqlite3

# Database Name (file path for SQLite, database name for others)
DB_NAME=db.sqlite3

# Database Connection Settings (not needed for SQLite)
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ============================================
# EMAIL SETTINGS
# ============================================

# Email Backend Options:
# - django.core.mail.backends.console.EmailBackend (development)
# - django.core.mail.backends.smtp.EmailBackend (production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Settings (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# ============================================
# SECURITY SETTINGS
# ============================================

# CSRF Trusted Origins - Comma separated list
# Example: https://example.com,https://www.example.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# CORS Settings (if using django-cors-headers)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security Headers (set to True in production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ============================================
# STATIC & MEDIA FILES
# ============================================

# Static files URL
STATIC_URL=/static/
STATIC_ROOT=staticfiles

# Media files URL (user uploads)
MEDIA_URL=/media/
MEDIA_ROOT=media

# ============================================
# LOCALIZATION
# ============================================

# Language Code (e.g., en-us, id-id, ja-jp)
LANGUAGE_CODE=en-us

# Time Zone (e.g., UTC, Asia/Jakarta, America/New_York)
TIME_ZONE=UTC

# ============================================
# LOGGING
# ============================================

# Log Level Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ============================================
# CACHE SETTINGS
# ============================================

# Cache Backend Options:
# - django.core.cache.backends.locmem.LocMemCache (development)
# - django.core.cache.backends.redis.RedisCache (production)
# - django.core.cache.backends.memcached.PyMemcacheCache
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache

# Redis URL (if using Redis)
REDIS_URL=redis://localhost:6379/0

# ============================================
# CELERY SETTINGS (if using Celery)
# ============================================

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# THIRD PARTY API KEYS
# ============================================

# Add your API keys here
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=

# ============================================
# APPLICATION SPECIFIC SETTINGS
# ============================================

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# JWT Settings (if using djangorestframework-simplejwt)
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7
